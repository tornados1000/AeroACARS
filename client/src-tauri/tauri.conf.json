{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AeroACARS",
  "version": "0.13.9",
  "identifier": "com.aeroacars.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AeroACARS",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https: wss://live.kant.ovh https://www.simbrief.com https://*.simbrief.com; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "crates/sim-msfs/ffi/lib/SimConnect.dll": "SimConnect.dll"
    },
    "createUpdaterArtifacts": true,
    "publisher": "AeroACARS Project",
    "shortDescription": "Cross-platform ACARS client for phpVMS 7",
    "longDescription": "AeroACARS connects phpVMS 7 with MSFS 2020/2024 and X-Plane 11/12, recording flights, streaming live position data, and submitting full PIREPs with detailed runway and landing analysis."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MANFahrer-GF/AeroACARS/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREM0E0NzUxQzBGOTg0MDgKUldRSWhQbkFVVWM2VFFnMzJqRTVtM0pvQ285QTJPbFJBRWtIMXdUR3BDRkdtQWFFbm5lZzNiM2kK"
    }
  }
}
